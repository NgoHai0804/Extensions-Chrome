{
  "manifest_version": 3,
  "name": "Trợ lý YouTube",
  "description": "Tiện ích: lồng tiếng (phụ đề → dịch → TTS) và chặn quảng cáo trên YouTube.",
  "version": "3.4.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com;"
  },
  "permissions": ["storage", "webRequest", "declarativeNetRequest", "scripting", "webNavigation"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://youtu.be/*",
    "*://*.youtube-nocookie.com/*",
    "https://translate.googleapis.com/*",
    "https://clients5.google.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Trợ lý YouTube",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://youtu.be/*",
        "*://*.youtube-nocookie.com/*"
      ],
      "js": [
        "content/dubbing/core/settings.js",
        "content/dubbing/core/constants.js",
        "content/dubbing/core/config.js",
        "content/dubbing/core/logging.js",
        "content/dubbing/cc-constants.js",
        "content/dubbing/modules/content-env.js",
        "content/dubbing/modules/content-ui.js",
        "content/dubbing/modules/content-tts.js",
        "content/dubbing/modules/subtitle-utils.js",
        "content/dubbing/runtime.js",
        "content/dubbing/ui.js",
        "content/dubbing/helpers.js",
        "content/dubbing/subtitle-loader.js",
        "content/dubbing/subtitle-timeline.js",
        "content/dubbing/tts.js",
        "content/dubbing/playback.js",
        "content/adblock/adblock-init.js",
        "content/content.js"
      ],
      "css": ["content/dubbing/content.css", "content/adblock/adblock.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/dubbing/page-bridge.js", "content/dubbing/cc-main-world.js"],
      "matches": [
        "*://*.youtube.com/*",
        "*://youtu.be/*",
        "*://*.youtube-nocookie.com/*"
      ]
    }
  ]
}
