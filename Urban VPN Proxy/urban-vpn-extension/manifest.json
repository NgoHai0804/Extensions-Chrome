{
  "manifest_version": 3,
  "name": "Urban VPN Proxy Helper",
  "version": "1.0.0",
  "description": "Tự động đăng ký ẩn danh, lấy token, danh sách quốc gia và proxy từ UrbanVPN API.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://api-pro.urban-vpn.com/*",
    "https://stats.falais.com/*",
    "https://api-pro.falais.com/*",
    "https://api.ipify.org/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Urban VPN Proxy",
    "default_popup": "popup.html"
  },
  "icons": {
    "48": "assets/icon-48.png"
  }
}
